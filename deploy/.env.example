# Copy to .env and edit, then run ./setup.sh (advanced path).
# Most people should run ../install.sh instead — a guided wizard that fills this in for you.
# No hardcoded paths or personal values live in the repo.

# Where the server code + venv + index live (this repo gets copied here at deploy)
POKE_APP_DIR="$HOME/poke-memory"
# The markdown vault (created if missing; one card folder per kind + an inbox)
POKE_VAULT_ROOT="$HOME/poke-vault"

# Local bind port for the MCP (kept on 127.0.0.1; the tunnel fronts it)
POKE_VAULT_PORT="8077"
# Seconds before the index is reported "stale" in every search response
POKE_VAULT_STALE_AFTER="3600"
# How often the scheduled full reindex runs (seconds)
REINDEX_INTERVAL="900"
# Hybrid retrieval blend (0-1): 1.0 pure semantic, 0.0 pure keyword/BM25, default 0.7. Per-call overridable.
POKE_VECTOR_WEIGHT="0.7"

# --- Embeddings ---
# EMBED_MODE: sentence-transformers (local, no API, works offline — recommended default)
#           | openai (any OpenAI-compatible endpoint: ollama, llama.cpp, an internal server, OpenAI itself)
EMBED_MODE="sentence-transformers"
EMBED_MODEL="BAAI/bge-small-en-v1.5"
# Only used when EMBED_MODE=openai. Examples:
#   ollama:  EMBED_API_BASE="http://127.0.0.1:11434/v1"  EMBED_MODEL="bge-m3"          EMBED_API_KEY="ollama"
#   OpenAI:  EMBED_API_BASE="https://api.openai.com/v1"   EMBED_MODEL="text-embedding-3-small"  EMBED_API_KEY="sk-..."
EMBED_API_BASE=""
EMBED_API_KEY=""
# Optional: overlay a patched leann-core (editable) so the OpenAI client honors LEANN_OPENAI_TIMEOUT,
# freeing a search worker (~10s) instead of pinning it ~600s on a stalled remote embed. Point at the
# leann-core PACKAGE dir. Leave unset for stock PyPI leann (still safe; the caller is bounded at 8s).
# LEANN_SRC="/path/to/LEANN-fork/packages/leann-core"

# --- Cloudflare named tunnel (public ingress; needed for Poke to reach you) ---
# Only used by ./setup.sh / the "named tunnel" path of install.sh.
CLOUDFLARED_BIN="/opt/homebrew/bin/cloudflared"
CF_TUNNEL_NAME="poke-memory"
# Tunnel UUID from: cloudflared tunnel list
CF_TUNNEL_ID="00000000-0000-0000-0000-000000000000"
# Credentials json written by: cloudflared tunnel create
CF_CRED_FILE="$HOME/.cloudflared/${CF_TUNNEL_ID}.json"
# Public hostname routed to this tunnel (must be a zone in your cert.pem, or create the CNAME via the DNS API)
CF_HOSTNAME="memory.example.com"

# INGRESS picks how Poke reaches you: named | cfapi | quick | ngrok | tailscale | none
# named  -> the CF_* vars above (cloudflared tunnel login, browser)
# cfapi  -> CF_API_TOKEN + CF_ACCOUNT_ID + CF_HOSTNAME (no browser; agent-friendly)
# quick  -> CLOUDFLARED_BIN only (ephemeral trycloudflare URL; get it with: poke-vault tunnel-url)
# ngrok  -> NGROK_BIN (run 'ngrok config add-authtoken <token>' once; get URL with: poke-vault tunnel-url)
INGRESS="named"
NGROK_BIN="/opt/homebrew/bin/ngrok"

# --- Message ingest (keeps the Poke iMessage thread captured into the vault) ---
# Needs imsg + Full Disk Access (see README). 1=on (daily), 0=off.
# Messages are sharded by local day; the ingest runs once daily at INGEST_HOUR:INGEST_MINUTE
# (local time) and captures the day that just closed. Defaults to 00:15. Out-of-range values
# fall back to the defaults.
INGEST="1"
INGEST_HOUR="0"
INGEST_MINUTE="15"
# Poke-thread matchers (name regex is the universal AMB matcher; numbers optional, e.g. a legacy thread)
POKE_NAME_REGEX="^poke$"
POKE_NUMBERS=""
POKE_IDENTIFIERS=""
